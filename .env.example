# Social Data Crawler - Environment Variables
# Copy to .env and fill in your values

# === Twitter/X API (optional - for API expansion) ===
# Get from https://developer.twitter.com/
X_BEARER_TOKEN=

# === Base Chain / Etherscan V2 API (optional) ===
# Basescan V1 is deprecated. Use Etherscan V2 with chainid=8453 for Base.
# Get key from https://etherscan.io/myapikey (one key works for all chains).
# Balance and token queries work without a key (via JSON-RPC).
# Transaction listing (expand_via_api) requires a key.
BASESCAN_API_KEY=
ETHERSCAN_API_KEY=

# === LinkedIn (requires browser cookies, not env vars) ===
# Export cookies to JSON file and pass via --cookies flag
# See SKILL.md for instructions
