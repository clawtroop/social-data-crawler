"""Enrichment orchestrator - legacy interface.

This module provides backward-compatible functions that internally
delegate to the new EnrichPipeline. Use these functions when you need
the legacy dict-based interface.

For new code, prefer using EnrichPipeline directly.
"""
from __future__ import annotations

import asyncio
from datetime import UTC, datetime
from typing import Any, Mapping, Sequence

from crawler.enrich.generative.llm_client import LLMEmptyResponseError, LLMRequestError
from crawler.enrich.schemas.field_group_registry import get_field_group_spec
from crawler.enrich.templates import get_field_group_template, route_field_group


def initialize_enrichment_envelope(
    mode: str,
    model: str,
    field_groups: Sequence[str] | None = None,
    model_config: Mapping[str, Any] | None = None,
) -> dict:
    """Initialize an enrichment result envelope."""
    return {
        "status": "pending",
        "mode": mode,
        "field_groups": list(field_groups or []),
        "generated_fields": {},
        "evidence": {},
        "confidence": {},
        "source_fields": {},
        "unsupported_reason": {},
        "model": model,
        "model_config": dict(model_config or {}),
        "generated_at": datetime.now(UTC).isoformat(),
    }


def route_enrichment(
    record: Mapping[str, Any],
    field_groups: Sequence[str] | None = None,
    model_config: Mapping[str, Any] | None = None,
    mode: str = "planned",
) -> dict:
    """
    Route enrichment through field groups.

    This is the legacy interface. For new code, use EnrichPipeline.enrich().
    """
    requested_field_groups = list(field_groups or [])
    model_name = str((model_config or {}).get("model", "catalog-only"))
    envelope = initialize_enrichment_envelope(
        mode=mode,
        model=model_name,
        field_groups=requested_field_groups,
        model_config=model_config,
    )
    envelope["status"] = "routed"

    # Use the template-based routing for legacy compatibility
    for field_group in requested_field_groups:
        routed = route_field_group(field_group, record, model_config=model_config)
        if routed["unsupported_reason"] == "unsupported field group":
            envelope["unsupported_reason"][field_group] = routed["unsupported_reason"]
            continue

        spec = get_field_group_spec(field_group)
        if spec is not None and spec.strategy in {"generative_only", "extractive_then_generative"}:
            generated = _execute_field_group_with_llm(
                field_group=field_group,
                record=record,
                routed=routed,
                model_config=model_config,
            )
        else:
            generated = dict(routed)

        if routed["unsupported_reason"] is not None:
            envelope["unsupported_reason"][field_group] = routed["unsupported_reason"]
        envelope["generated_fields"][field_group] = generated["generated_fields"]
        envelope["confidence"][field_group] = generated["confidence"]
        envelope["evidence"][field_group] = generated["evidence"]
        envelope["source_fields"][field_group] = generated["source_fields"]
        if generated.get("unsupported_reason") is not None:
            envelope["unsupported_reason"][field_group] = generated["unsupported_reason"]

    return envelope


def _execute_field_group_with_llm(
    *,
    field_group: str,
    record: Mapping[str, Any],
    routed: Mapping[str, Any],
    model_config: Mapping[str, Any] | None,
) -> dict[str, Any]:
    """Execute a field group using the new LLM client."""
    model_config = dict(model_config or {})
    template = get_field_group_template(field_group)
    if template is None:
        raise ValueError(f"Generative field group '{field_group}' has no legacy template")

    provider = str(model_config.get("provider", "")).lower()
    base_url = str(model_config.get("base_url", "")).strip()
    model_name = str(model_config.get("model", "")).strip()
    if provider not in {"openai", "openai_compatible", "compatible"} or not base_url or not model_name:
        raise ValueError(f"AI configuration required for generative field group '{field_group}'")

    # Use new LLM client from pipeline module
    from crawler.enrich.generative.llm_client import LLMClient

    source_payload = dict(routed["source_fields"])
    prompt = template.render_prompt(source_payload)

    client = LLMClient.from_model_config(model_config)

    # Run async completion synchronously
    try:
        response = asyncio.run(client.complete(
            prompt,
            model=model_config.get("model"),
            temperature=float(model_config.get("temperature", 0.2)),
        ))
    except LLMEmptyResponseError as exc:
        raise RuntimeError(f"LLM returned empty response for field group '{field_group}'") from exc
    except LLMRequestError as exc:
        raise RuntimeError(f"LLM request failed for field group '{field_group}'") from exc

    return {
        "generated_fields": {template.output_field: response.content},
        "confidence": routed["confidence"],
        "evidence": routed["evidence"],
        "source_fields": source_payload,
        "unsupported_reason": None,
    }
