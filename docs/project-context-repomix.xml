        mock_response.json.side_effect = Exception("not json")

        async def run():
            with patch("crawler.fetch.engine.httpx.AsyncClient") as mock_client_cls:
                mock_client = AsyncMock()
                mock_client.get = AsyncMock(return_value=mock_response)
